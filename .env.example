# Banco
DB_USER=tools_user
DB_PASSWORD=tools_pass
DB_NAME=loja_ferramentas

# JWT (obrigatorio no backend)
# Use uma chave longa e aleatoria (minimo 32 caracteres)
JWT_SECRET=troque_esta_chave_por_uma_muito_forte_com_32_ou_mais_caracteres
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS (lista explicita de origens separadas por virgula)
CORS_ALLOWED_ORIGINS=https://meusite.com

# Bootstrap de admin (opcional)
# Em producao, prefira criar admin por fluxo interno/seguro e manter false
APP_ADMIN_BOOTSTRAP_ENABLED=false
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@empresa.com
APP_ADMIN_NAME=Administrador
APP_ADMIN_PASSWORD=troque_esta_senha_forte
