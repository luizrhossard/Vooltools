# Banco
DB_USER=tools_user
DB_PASSWORD=tools_pass
DB_NAME=loja_ferramentas

# JWT (obrigatorio no backend)
JWT_SECRET=troque_esta_chave_dev_por_uma_com_32_ou_mais_caracteres
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS para desenvolvimento local
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Desenvolvimento local: pode ser true para agilizar bootstrap.
# NUNCA habilite APP_ADMIN_BOOTSTRAP_ENABLED em producao.
APP_ADMIN_BOOTSTRAP_ENABLED=true
APP_ADMIN_USERNAME=
APP_ADMIN_EMAIL=
APP_ADMIN_NAME=Administrador
APP_ADMIN_PASSWORD=
